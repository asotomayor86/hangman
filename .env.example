# URL del hub (one-page-to-rule-them-all). Sin barra final.
HUB_URL=https://one-page-to-rule-them-all.vercel.app

# Secreto compartido con el hub para devolver resultados (lo da el admin del hub).
HUB_RESULT_SECRET=replace-me

# Secreto para firmar la cookie de sesión del juego (>= 32 caracteres).
# Si no se define, se reutiliza HUB_RESULT_SECRET.
AUTH_SIGNING_SECRET=replace-me-32-chars-or-more
